# Notion integration token. Required for build-time content fetch + /api/classify + /api/submit.
# Create one at https://www.notion.so/profile/integrations, then share the
# 🌌 AI TREE LIBRARY page (and its child databases) with the integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for the LLM auto-classify pipeline (Claude Haiku 4.5).
# Used by /api/classify when a URL is added or submitted.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile keys for the public submit form anti-spam.
# Get them from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAA
TURNSTILE_SECRET_KEY=0xBBBBBBBBBBBBBBBBBBB

# Optional: Resend API key for the "thanks, we'll review" auto-reply email
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Shared secret used between Notion automation webhook and /api/classify
# Generate any random string: openssl rand -hex 32
CLASSIFY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
